<section id="contacto" class="py-20 px-4 sm:px-6 lg:px-8 relative z-10">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16 reveal-on-scroll">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">Contacto</h2>
      <div class="w-24 h-1 bg-gradient-to-r from-pink-500 to-orange-500 mx-auto rounded-full"></div>
      <p class="text-gray-400 mt-6 max-w-2xl mx-auto">
        ¿Interesado en trabajar juntos o tienes alguna pregunta? No dudes en contactarme.
      </p>
    </div>

    <div class="flex flex-col md:flex-row justify-center items-center gap-6">
      <!-- Email -->
      <a href="mailto:luisfercobre3@gmail.com" class="liquid-glass p-6 w-full md:w-auto min-w-[250px] flex flex-col items-center gap-4 group reveal-on-scroll delay-100">
        <div class="w-12 h-12 rounded-full bg-cyan-500/10 flex items-center justify-center text-cyan-400 group-hover:scale-110 group-hover:bg-cyan-500/20 transition-all">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        </div>
        <div class="text-center">
          <h3 class="text-white font-medium mb-1">Email</h3>
          <p class="text-gray-400 text-sm">luisfercobre3@gmail.com</p>
        </div>
      </a>
      
      <!-- Teléfono -->
      <a href="tel:9981355680" class="liquid-glass p-6 w-full md:w-auto min-w-[250px] flex flex-col items-center gap-4 group reveal-on-scroll delay-200">
        <div class="w-12 h-12 rounded-full bg-purple-500/10 flex items-center justify-center text-purple-400 group-hover:scale-110 group-hover:bg-purple-500/20 transition-all">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
        </div>
        <div class="text-center">
          <h3 class="text-white font-medium mb-1">Teléfono</h3>
          <p class="text-gray-400 text-sm">998-135-5680</p>
        </div>
      </a>

      <!-- LinkedIn -->
      <a href="https://linkedin.com/in/tu-perfil" target="_blank" rel="noopener noreferrer" class="liquid-glass p-6 w-full md:w-auto min-w-[250px] flex flex-col items-center gap-4 group reveal-on-scroll delay-300">
        <div class="w-12 h-12 rounded-full bg-blue-600/10 flex items-center justify-center text-blue-500 group-hover:scale-110 group-hover:bg-blue-600/20 transition-all">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </div>
        <div class="text-center">
          <h3 class="text-white font-medium mb-1">LinkedIn</h3>
          <p class="text-gray-400 text-sm">Conectar</p>
        </div>
      </a>
    </div>
  </div>
</section>

<footer class="py-8 text-center text-gray-500 text-sm border-t border-white/5 relative z-10 mt-12 reveal-on-scroll">
  <p>© {new Date().getFullYear()} Luis Fernando Fuentes Kumul. Todos los derechos reservados.</p>
</footer>
